{
  "name": "@factory/shared",
  "version": "1.0.0",
  "description": "MERN SaaS Factory Framework — shared core, white-label config and design system",
  "exports": {
    "./design-sys/theme/*": {
      "types": "./dist/design-sys/theme/*.d.ts",
      "default": "./dist/design-sys/theme/*.js"
    },
    "./design-sys/atoms/*": {
      "types": "./dist/design-sys/atoms/*/index.d.ts",
      "default": "./dist/design-sys/atoms/*/index.js"
    },
    "./design-sys/organisms/*": {
      "types": "./dist/design-sys/organisms/*/index.d.ts",
      "default": "./dist/design-sys/organisms/*/index.js"
    },
    "./design-sys/organisms/LegalPages/*": {
      "types": "./dist/design-sys/organisms/LegalPages/*/index.d.ts",
      "default": "./dist/design-sys/organisms/LegalPages/*/index.js"
    },
    "./design-sys/organisms/LegalPages/shared/*": {
      "types": "./dist/design-sys/organisms/LegalPages/shared/*.d.ts",
      "default": "./dist/design-sys/organisms/LegalPages/shared/*.js"
    },
    "./design-sys/mixins/*": {
      "types": "./dist/design-sys/mixins/*.d.ts",
      "default": "./dist/design-sys/mixins/*.js"
    },
    "./config/*": {
      "types": "./dist/config/*.d.ts",
      "default": "./dist/config/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "default": "./dist/i18n/index.js"
    },
    "./i18n/pages": {
      "types": "./dist/i18n/pages/index.d.ts",
      "default": "./dist/i18n/pages/index.js"
    },
    "./i18n/locales": {
      "types": "./dist/i18n/locales/index.d.ts",
      "default": "./dist/i18n/locales/index.js"
    },
    "./i18n/locales/*": {
      "types": "./dist/i18n/locales/*/index.d.ts",
      "default": "./dist/i18n/locales/*/index.js"
    },
    "./i18n/*": {
      "types": "./dist/i18n/*.d.ts",
      "default": "./dist/i18n/*.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist node_modules",
    "audit:i18n": "node scripts/audit_i18n.js"
  },
  "peerDependencies": {
    "react": ">=18.0.0 || ^19.0.0",
    "react-dom": ">=18.0.0 || ^19.0.0",
    "antd": ">=5.0.0",
    "styled-components": ">=5.3.0 || ^6.0.0",
    "@ant-design/icons": "^5.0.0"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "antd": "^5.26.6",
    "styled-components": "^6.0.0",
    "@ant-design/icons": "^5.6.1",
    "@types/react": "^19.0.0",
    "@types/styled-components": "^5.1.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}