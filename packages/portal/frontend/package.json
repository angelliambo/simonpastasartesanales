{
  "name": "@factory/frontend",
  "version": "1.2.2",
  "proxy": "http://localhost:5000",
  "private": true,
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@react-oauth/google": "^0.13.5",
    "@reduxjs/toolkit": "^2.9.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@factory/shared": "1.1.0",
    "antd": "^5.26.6",
    "react": "^19.1.0",
    "react-app-rewired": "^2.2.1",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^2.0.5",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.1",
    "react-scripts": "5.0.1",
    "styled-components": "^6.1.19",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@types/babel__core": "^7.20.5",
    "@types/body-parser": "^1.19.6",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "babel-plugin-styled-components": "^2.1.4",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "identity-obj-proxy": "^3.0.0",
    "ts-jest": "^29.4.1",
    "webpack-bundle-analyzer": "^5.0.1"
  },
  "scripts": {
    "update-seo": "npx tsx scripts/update-seo.ts",
    "clean": "rm -rf build node_modules",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=8192 react-app-rewired start",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 react-app-rewired build",
    "analyze": "cross-env NODE_OPTIONS=--max-old-space-size=6144 ANALYZE=true react-app-rewired build",
    "test": "cross-env CI=true react-app-rewired test --watch=false --runInBand",
    "test:ci": "cross-env CI=true react-app-rewired test --watch=false --runInBand",
    "test:watch": "react-app-rewired test --watch",
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint \"src/**/*.{ts,tsx}\"",
    "eject": "react-scripts eject",
    "gp": "node ../../../scripts/gp.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      },
      "project": "./tsconfig.json"
    },
    "plugins": [
      "@typescript-eslint"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": "warn",
      "@typescript-eslint/no-explicit-any": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    }
  }
}