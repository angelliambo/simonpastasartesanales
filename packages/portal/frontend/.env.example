# =========================================================================
# ARCHIVO DE EJEMPLO DE VARIABLES DE ENTORNO PARA EL PORTAL WEB (FRONTEND)
# Copia este archivo como '.env', '.env.development' o '.env.production'
# y completa los valores con tus credenciales reales.
# =========================================================================

# URL del backend (Local: http://localhost:5000/api | Producción: https://tu-dominio.com/api)
REACT_APP_API_URL=http://localhost:5000/api

# Client ID de Google OAuth 2.0 (Google Identity Services)
REACT_APP_GOOGLE_CLIENT_ID=tu_client_id_de_google_oauth

# ID de Google Analytics (GA4 - Ej: G-XXXXXXXXXX)
REACT_APP_GA_MEASUREMENT_ID=tu_ga_measurement_id

# Google Maps API Key (Para el mapa interactivo de contacto)
REACT_APP_GOOGLE_MAPS_API_KEY=tu_google_maps_api_key

# Configuración del SDK de Firebase
# (Se inicializará Firebase Analytics automáticamente si se definen estas variables)
REACT_APP_FIREBASE_API_KEY=tu_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=tu_proyecto_firebase.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=tu_proyecto_firebase
REACT_APP_FIREBASE_STORAGE_BUCKET=tu_proyecto_firebase.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=tu_firebase_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=tu_firebase_measurement_id
