{
  "name": "@factory/backend",
  "version": "1.2.2",
  "description": "MERN SaaS Factory Framework — Scalable Express & MongoDB Backend",
  "main": "server.js",
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "test": "jest",
    "test-email": "cross-env NODE_ENV=development tsx -r dotenv/config ./scripts/test-email.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "dev": "cross-env NODE_ENV=development nodemon --watch './**/*.ts' --exec tsx -r dotenv/config ./server.ts",
    "start": "cross-env NODE_ENV=production npx tsx dist/server.js",
    "seed": "tsx -r dotenv/config ./seeder/seeder.ts",
    "gp": "node ../../../scripts/gp.js"
  },
  "license": "MIT",
  "dependencies": {
    "@factory/shared": "^1.2.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.4.2",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}