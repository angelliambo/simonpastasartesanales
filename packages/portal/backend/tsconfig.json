{
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": false,
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ],
    "paths": {
      "@factory/shared/*": [
        "../../../shared/dist/*"
      ]
    },
    "allowImportingTsExtensions": false,
    "noEmitOnError": false
  },
  "include": [
    "./**/*.ts",
    "server.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests/**/*",
    "**/*.test.ts",
    "**/*.spec.ts",
    "clean-db.ts",
    "seeder/**/*",
    "utils/**/*"
  ]
}