# =========================================================================
# ARCHIVO DE EJEMPLO DE VARIABLES DE ENTORNO PARA EL BACKEND (BFF)
# Copia este archivo como '.env', '.env.development' o '.env.production'
# y completa los valores con tus credenciales reales.
# =========================================================================

# Configuración básica del servidor
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ID del administrador inicial del sistema (Para acceso al panel de administración)
ADMIN_ID=tu_admin_id_mongodb

# URI de conexión a la base de datos (MongoDB)
# Local: mongodb://localhost:27017/tu-db
# Producción: mongodb+srv://usuario:password@cluster.mongodb.net/tu-db
BBD=mongodb://localhost:27017/factory-dev

# Configuración de cifrado y tokens JWT
# (Genera claves seguras y largas de 64 caracteres hexadecimales)
JWT_SECRET_KEY=tu_jwt_secret_key_segura
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=tu_encryption_key_segura_de_32_bytes

# Configuración de Logs (Valores: debug, info, warn, error)
LOG_LEVEL=debug
LOG_REQUESTS=true
LOG_ERRORS=true
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_LOGGING=true
ENABLE_DETAILED_ERRORS=true

# Google OAuth 2.0 (Debe coincidir con la del frontend)
GOOGLE_CLIENT_ID=tu_google_client_id

# Configuración de Email (MailSender o SendGrid)
# Para MailSender: setea EMAIL_PROVIDER=sender e EMAIL_API_KEY
# Para SendGrid: setea EMAIL_PROVIDER=sendgrid y SENDGRID_API_KEY
EMAIL_PROVIDER=sender
EMAIL_API_KEY=tu_mailsender_api_key
SENDGRID_API_KEY=tu_sendgrid_api_key

# Remitente de email
CONTACT_EMAIL=support@tu-dominio.com
EMAIL_FROM_EMAIL=noreply@tu-dominio.com
EMAIL_FROM_NAME=TuMarca

# Secreto de validación para God Mode (Acceso premium de bypass)
GOD_MODE_SECRET=tu_secreto_god_mode

# LemonSqueezy (Pagos y suscripciones)
LEMONSQUEEZY_API_KEY=tu_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=tu_lemonsqueezy_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=tu_lemonsqueezy_webhook_secret
LEMONSQUEEZY_6M_VARIANT_ID=tu_variant_id_plan_6m
LEMONSQUEEZY_1Y_VARIANT_ID=tu_variant_id_plan_1y

# Integración con RapidAPI para Instagram
RAPIDAPI_KEY=tu_rapidapi_key
RAPIDAPI_HOST=instagram-looter.p.rapidapi.com
RAPIDAPI_ENDPOINT=/ig/posts_username/?nocors=false
INSTAGRAM_DEFAULT_USERNAME=tu_cuenta_instagram_por_defecto
SOCIAL_FEED_CACHE_TTL=21600000
